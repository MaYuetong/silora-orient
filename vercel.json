{
  "version": 2,
  "name": "silora-orient",
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html",   "use": "@vercel/static" },
    { "src": "*.css",    "use": "@vercel/static" },
    { "src": "main.js",  "use": "@vercel/static" },
    { "src": "content/**", "use": "@vercel/static" },
    { "src": "images/**",  "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/$1"     }
  ]
}
